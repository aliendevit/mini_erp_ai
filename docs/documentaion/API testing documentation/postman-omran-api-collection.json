            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ورشة الشام للبلاط والعزل\",\n  \"contactName\": \"Abu Samer\",\n  \"phone\": \"0933445566\",\n  \"email\": \"workshop@example.com\",\n  \"specialties\": [\n    \"tile\",\n    \"waterproofing\",\n    \"ceramic\"\n  ],\n  \"notes\": \"Preferred workshop for tile and waterproofing work.\",\n  \"availabilityStatus\": \"available\",\n  \"isActive\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is ok', function () { pm.expect(pm.response.code).to.be.oneOf([200, 201]); });",
                  "const data = pm.response.json();",
                  "if (data.id) pm.collectionVariables.set('workshop_id', data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Workshop",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/workshops/{{workshop_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "workshops",
                "{{workshop_id}}"
              ]
            },
            "description": "Reads selected workshop."
          },
          "response": []
        }
      ]
    },
