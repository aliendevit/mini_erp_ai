        </mxCell>
        <mxCell id="6aUyTjWssD2qijPah5Gx-13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" value="AssemblyAI transcribes audio" vertex="1">
          <mxGeometry height="70" width="240" x="1872" y="2019.0033333333336" as="geometry" />
        </mxCell>
        <mxCell id="6aUyTjWssD2qijPah5Gx-14" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" value="Transcript found?" vertex="1">
          <mxGeometry height="110" width="220" x="1882" y="2223.0033333333336" as="geometry" />
        </mxCell>
        <mxCell id="6aUyTjWssD2qijPah5Gx-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" value="Insert transcript into input for user review" vertex="1">
